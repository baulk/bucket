        }
    },
    "extension": "zip",
    "force_delete": [
        "${BAULK_VFS}\\.konan"
    ],
    "venv": {
        "category": "kotlin",
        "dependencies": [
            "zulu"
        ],
        "path": [
            "${BAULK_PKGROOT}\\bin"
        ],
