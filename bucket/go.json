{
    "description": "An open source programming language that makes it easy to build simple, reliable, and efficient software.",
    "version": "1.26.0",
    "homepage": "https://golang.org/",
    "license": "BSD",
    "architecture": {
        "64bit": {
            "url": "https://go.dev/dl/go1.26.0.windows-amd64.zip",
            "hash": "sha256:9bbe0fc64236b2b51f6255c05c4232532b8ecc0e6d2e00950bd3021d8a4d07d4"
        },
        "arm64": {
            "url": "https://go.dev/dl/go1.26.0.windows-arm64.zip",
            "hash": "sha256:73bdbb9f64aa152758024485c5243a1098182bb741fcc603b6fb664ee5e0fe35"
        }
    },
    "extension": "zip",
    "force_delete": [
        "${BAULK_VFS}\\go",
        "${BAULK_VFS}\\Temp\\go-build"
    ],
    "venv": {
        "category": "golang",
        "mkdir": [
            "${BAULK_VFS}\\Temp"
        ],
        "path": [
            "${BAULK_PKGROOT}\\bin",
            "${BAULK_VFS}\\go\\bin"
        ],
        "env": [
            "GOPATH=${BAULK_VFS}\\go",
            "GOENV=${BAULK_VFS}\\go\\env",
            "GOCACHE=${BAULK_VFS}\\Temp\\go-build",
            "GOTMPDIR=${BAULK_VFS}\\Temp",
            "GO111MODULE=on",
            "GO_PROXY=https://goproxy.io"
        ]
    }
}
