{
    "description": "An open source programming language that makes it easy to build simple, reliable, and efficient software.",
    "version": "1.26.3",
    "homepage": "https://golang.org/",
    "license": "BSD",
    "architecture": {
        "64bit": {
            "url": "https://go.dev/dl/go1.26.3.windows-amd64.zip",
            "hash": "sha256:20d2ceafb4ed41b96b879010927b28bc92a5be57a7c1801ce365a9ca51d3224a"
        },
        "arm64": {
            "url": "https://go.dev/dl/go1.26.3.windows-arm64.zip",
            "hash": "sha256:95cd63bc6b0da77409ba819215afea9ddf5702c55a3b20af3dd90ea95c7b130c"
        }
    },
    "extension": "zip",
    "force_delete": [
        "${BAULK_VFS}\\go",
        "${BAULK_VFS}\\Temp\\go-build"
    ],
    "venv": {
        "category": "golang",
        "mkdir": [
            "${BAULK_VFS}\\Temp"
        ],
        "path": [
            "${BAULK_PKGROOT}\\bin",
            "${BAULK_VFS}\\go\\bin"
        ],
        "env": [
            "GOPATH=${BAULK_VFS}\\go",
            "GOENV=${BAULK_VFS}\\go\\env",
            "GOCACHE=${BAULK_VFS}\\Temp\\go-build",
            "GOTMPDIR=${BAULK_VFS}\\Temp",
            "GO111MODULE=on",
            "GO_PROXY=https://goproxy.io"
        ]
    }
}
